{
  "cli": {
    "version": ">= 17.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "qa": {
      "extends": "base",
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "qa"
      }
    },
    "staging": {
      "extends": "base",
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "staging"
      }
    },
    "production": {
      "extends": "base",
      "distribution": "store",
      "env": {
        "APP_VARIANT": "production"
      }
    },
    "production-apk": {
      "extends": "production",
      "android": {
        "buildType": "apk"
      }
    },
    "base": {
      "ios": {
        "autoIncrement": true
      },
      "android": {
        "autoIncrement": true
      }
    }
  }
}
