generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  PERSONAL
}

enum AccountStatus {
  ONBOARDING
  ACTIVE
}

enum Role {
  OWNER
}

model Account {
  id        String        @id @default(uuid())
  type      AccountType   @default(PERSONAL)
  status    AccountStatus @default(ONBOARDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  users     User[]
  vehicles  Vehicle[]
}

model User {
  id                         String         @id @default(uuid())
  accountId                  String
  account                    Account        @relation(fields: [accountId], references: [id])
  fullName                   String
  email                      String         @unique
  passwordHash               String
  role                       Role           @default(OWNER)
  emailVerified              Boolean        @default(false)
  verificationToken          String?
  verificationTokenExpiresAt DateTime?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  refreshTokens              RefreshToken[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Vehicle {
  id        String   @id @default(uuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
  nickname  String?
  make      String
  model     String
  year      Int
  mileage   Int
  photoPath String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}
