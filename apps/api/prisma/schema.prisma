generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  PERSONAL
}

enum PremiumPeriod {
  MONTHLY
  QUARTERLY
  BIANNUAL
  ANNUAL
}

enum AccountStatus {
  ONBOARDING
  ACTIVE
}

enum Role {
  OWNER
}

model Account {
  id        String        @id @default(uuid())
  type      AccountType   @default(PERSONAL)
  status    AccountStatus @default(ONBOARDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  users     User[]
  vehicles  Vehicle[]
}

model User {
  id                         String         @id @default(uuid())
  accountId                  String
  account                    Account        @relation(fields: [accountId], references: [id])
  fullName                   String
  email                      String         @unique
  passwordHash               String
  role                       Role           @default(OWNER)
  emailVerified              Boolean        @default(false)
  verificationToken          String?
  verificationTokenExpiresAt DateTime?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  refreshTokens              RefreshToken[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

enum VehicleTransferStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

model Vehicle {
  id         String            @id @default(uuid())
  accountId  String
  account    Account           @relation(fields: [accountId], references: [id])
  nickname   String?
  make       String
  model      String
  year       Int
  mileage    Int
  photoPath  String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  logEntries LogEntry[]
  insurance  VehicleInsurance?
  transfers  VehicleTransfer[]

  @@index([accountId])
}

model VehicleTransfer {
  id                 String                @id @default(uuid())
  vehicleId          String
  vehicle            Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  senderAccountId    String
  recipientEmail     String
  recipientAccountId String?
  token              String                @unique @default(uuid())
  status             VehicleTransferStatus @default(PENDING)
  expiresAt          DateTime
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([vehicleId])
  @@index([token])
}

model VehicleInsurance {
  id            String         @id @default(uuid())
  vehicleId     String         @unique
  vehicle       Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  company       String?
  policyNumber  String?
  startDate     DateTime?
  expiryDate    DateTime?
  premium       Decimal?       @db.Decimal(10, 2)
  premiumPeriod PremiumPeriod?
  towNumber     String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Lookup table — id is the stable string key.
// Back-relation entries LogEntry[] exists ONLY for Prisma schema syntax.
// NEVER include it in queries.
model LogEntryType {
  id      String     @id
  entries LogEntry[] // back-relation — do NOT include in queries
}

// Lookup table — same pattern.
model ItemCategory {
  id    String    @id
  items LogItem[] // back-relation — do NOT include in queries
}

model LogEntry {
  id        String       @id @default(uuid())
  vehicleId String
  vehicle   Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  typeId    String
  type      LogEntryType @relation(fields: [typeId], references: [id])
  title     String
  date      DateTime     @db.Date
  time      String?      // "HH:mm" or null
  mileage   Int?
  notes     String?
  items     LogItem[]
  media     LogMedia[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([vehicleId])
  @@index([vehicleId, date])
}

model LogItem {
  id          String       @id @default(uuid())
  logEntryId  String
  logEntry    LogEntry     @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
  categoryId  String
  category    ItemCategory @relation(fields: [categoryId], references: [id])
  description String
  quantity    Decimal?     @db.Decimal(10, 3)
  unitCost    Decimal?     @db.Decimal(10, 2)
  sortOrder   Int          @default(0)
}

model LogMedia {
  id         String   @id @default(uuid())
  logEntryId String
  logEntry   LogEntry @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
  path       String
  mediaType  String   // "IMAGE" | "VIDEO"
  caption    String?
  sortOrder  Int      @default(0)
}
