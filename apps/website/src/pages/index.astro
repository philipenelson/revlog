---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <div id="top" class="flex flex-1 flex-col">
    <Header />

    <main class="flex flex-1 flex-col items-center justify-center px-6 py-24 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-accent">Coming soon</p>
      <h1 class="font-display text-4xl font-semibold tracking-tight text-text-primary sm:text-5xl">
        The Revlog landing page is under construction.
      </h1>
    </main>

    <Footer />
  </div>
</Layout>
