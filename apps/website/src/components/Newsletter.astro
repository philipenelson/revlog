---
---

<section id="newsletter" data-testid="newsletter-section" class="border-t border-border-muted px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-2xl text-center">
    <p class="mb-3 inline-flex items-center gap-2 text-sm font-semibold tracking-widest text-accent uppercase">
      <span class="h-px w-3.5 bg-current"></span>
      Stay in the loop
    </p>
    <h2 class="font-display text-3xl font-semibold tracking-tight text-text-primary sm:text-4xl">Get updates</h2>
    <p class="mt-4 text-lg text-text-secondary">
      Get an email when we ship new features and releases. No spam, unsubscribe any time.
    </p>

    <form data-testid="newsletter-form" novalidate class="mx-auto mt-8 flex max-w-md flex-col gap-3 sm:flex-row">
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        id="newsletter-email"
        name="email"
        type="email"
        inputmode="email"
        autocomplete="email"
        placeholder="you@example.com"
        data-testid="newsletter-email-input"
        class="w-full flex-1 rounded-md border border-border-default bg-surface-elevated px-4 py-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-accent focus:shadow-[var(--shadow-focus-ring)] focus:outline-none"
      />
      <button
        type="submit"
        data-testid="newsletter-submit"
        class="inline-flex shrink-0 items-center justify-center gap-2 rounded-md bg-accent px-6 py-3 text-sm font-semibold text-[var(--accent-contrast)] shadow-[var(--shadow-accent-btn)] transition-colors hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-60"
      >
        Subscribe
      </button>
    </form>

    <p data-testid="newsletter-validation-error" role="alert" class="mt-3 hidden text-sm text-danger">
      Enter a valid email address.
    </p>
    <p data-testid="newsletter-server-error" role="alert" class="mt-3 hidden text-sm text-danger">
      Something went wrong. Try again in a moment.
    </p>
    <p data-testid="newsletter-success" role="status" class="mt-3 hidden text-sm text-success">
      You're subscribed — thanks for following along.
    </p>
  </div>
</section>

<script>
  import { API_URL } from '../lib/env';

  const EMAIL_PATTERN = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const form = document.querySelector<HTMLFormElement>('[data-testid="newsletter-form"]');
  const emailInput = document.querySelector<HTMLInputElement>('[data-testid="newsletter-email-input"]');
  const submitButton = document.querySelector<HTMLButtonElement>('[data-testid="newsletter-submit"]');
  const validationError = document.querySelector<HTMLElement>('[data-testid="newsletter-validation-error"]');
  const serverError = document.querySelector<HTMLElement>('[data-testid="newsletter-server-error"]');
  const success = document.querySelector<HTMLElement>('[data-testid="newsletter-success"]');

  function hideMessages() {
    validationError?.classList.add('hidden');
    serverError?.classList.add('hidden');
    success?.classList.add('hidden');
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    hideMessages();

    const email = emailInput?.value.trim() ?? '';

    if (!EMAIL_PATTERN.test(email)) {
      validationError?.classList.remove('hidden');
      return;
    }

    if (submitButton) submitButton.disabled = true;

    try {
      const response = await fetch(`${API_URL}/newsletter/subscribe`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (!response.ok) {
        throw new Error(`Subscribe request failed with status ${response.status}`);
      }

      form.reset();
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    } catch {
      serverError?.classList.remove('hidden');
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
  });
</script>
