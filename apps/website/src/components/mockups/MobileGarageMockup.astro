---
import MotorcycleIcon from '../icons/MotorcycleIcon.astro';

const vehicles = [
  { name: 'The Daily', meta: 'Triumph Street Triple RS', odometer: '14,230 mi' },
  { name: 'Sunday Bike', meta: 'Ducati Scrambler Icon', odometer: '8,402 mi' },
  { name: 'Project Garage Find', meta: 'Honda CB350', odometer: '31,118 mi' },
];
---

<div class="px-4 pt-4 pb-6">
  <div class="mb-4 flex items-center justify-between">
    <span class="font-display text-sm leading-none tracking-tight">
      <span class="font-light text-text-primary">Rev</span><span class="font-bold text-accent">log</span>
    </span>
    <span class="flex h-7 w-7 items-center justify-center rounded-full border border-border-default bg-surface-elevated text-[10px] font-semibold text-text-secondary">
      JR
    </span>
  </div>

  <p class="mb-1 text-[10px] font-semibold tracking-[0.1em] text-accent uppercase">Your garage</p>
  <h4 class="mb-4 font-display text-lg font-semibold tracking-tight text-text-primary">3 vehicles</h4>

  <div class="flex flex-col gap-2.5">
    {
      vehicles.map((vehicle) => (
        <div class="flex items-center gap-3 rounded-lg border border-border-muted bg-surface-raised p-3">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md border border-border-default bg-surface-elevated text-accent">
            <MotorcycleIcon class="h-4 w-auto" />
          </div>
          <div class="min-w-0 flex-1">
            <div class="truncate text-sm font-semibold text-text-primary">{vehicle.name}</div>
            <div class="truncate text-[11px] text-text-tertiary">{vehicle.meta}</div>
          </div>
          <div class="shrink-0 font-mono text-xs text-text-secondary">{vehicle.odometer}</div>
        </div>
      ))
    }
  </div>
</div>
