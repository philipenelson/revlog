---
import MotorcycleIcon from '../icons/MotorcycleIcon.astro';

const stats = [
  { value: '12,400', unit: 'mi', label: 'Odometer' },
  { value: '14', unit: '', label: 'Log entries' },
  { value: 'Jun 3 2025', unit: '', label: 'Last logged', muted: true },
  { value: '$1,840', unit: '', label: 'Total spent' },
];
---

<div class="p-5 sm:p-6">
  <div class="relative h-28 overflow-hidden rounded-lg bg-surface-elevated sm:h-32">
    <div class="absolute -top-10 -right-10 h-36 w-36 rounded-full bg-[radial-gradient(circle,var(--accent-glow)_0%,transparent_70%)]"></div>
    <div class="absolute inset-0 flex items-center justify-center text-text-primary/10">
      <MotorcycleIcon class="h-20 w-auto" />
    </div>
    <div class="absolute inset-x-0 bottom-0 h-12 bg-gradient-to-t from-surface-base to-transparent"></div>
    <div class="absolute inset-x-4 bottom-2.5">
      <h4 class="font-display text-lg font-bold tracking-tight text-text-primary">Blackbird</h4>
      <p class="text-xs text-text-secondary">Honda · CB650R · 2019</p>
    </div>
  </div>

  <div class="relative z-10 -mt-3 grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-border-muted bg-border-muted sm:grid-cols-4">
    {
      stats.map((stat) => (
        <div class="bg-surface-raised px-3 py-2.5">
          <div class={`font-mono text-sm font-medium tracking-tight text-text-primary ${stat.muted ? 'font-sans' : ''}`}>
            {stat.value}
            {stat.unit && <span class="ml-0.5 text-[10px] font-normal text-text-tertiary">{stat.unit}</span>}
          </div>
          <div class="mt-1 text-[10px] tracking-[0.09em] text-text-tertiary uppercase">{stat.label}</div>
        </div>
      ))
    }
  </div>

  <div class="mt-4 flex flex-col gap-2">
    <h5 class="mb-1 font-display text-sm font-semibold tracking-tight text-text-primary">Service history</h5>

    <div class="flex items-center gap-3 rounded-md border border-border-muted bg-surface-raised px-3 py-2.5">
      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-sm bg-[var(--type-maintenance-bg)] text-[var(--type-maintenance-color)]">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path
            d="M12.5 3.5c-1.4-1.4-3.6-1.6-5.2-.5L9 4.9 7.2 6.7 5.4 4.8C4.3 6.3 4.5 8.5 5.9 9.9s3.6 1.6 5.2.5l3 2.9 1.2-1.2-2.9-3c1.2-1.5.9-3.8-.5-5.2-.1-.1-.3-.3-.4-.4z"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-[10px] font-bold tracking-[0.1em] text-[var(--type-maintenance-color)] uppercase">Maintenance</div>
        <div class="truncate text-sm font-semibold text-text-primary">Oil &amp; filter change</div>
        <div class="text-xs text-text-tertiary">Jun 3 2025 · 12,400 mi</div>
      </div>
      <div class="shrink-0 font-mono text-sm font-medium text-text-primary">$85.00</div>
    </div>

    <div class="flex items-center gap-3 rounded-md border border-border-muted bg-surface-raised px-3 py-2.5">
      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-sm bg-[var(--type-repair-bg)] text-[var(--type-repair-color)]">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path
            d="M8 2L5 8h3.5L5.5 14 13 7H9L12 2H8z"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-[10px] font-bold tracking-[0.1em] text-[var(--type-repair-color)] uppercase">Repair</div>
        <div class="truncate text-sm font-semibold text-text-primary">Front brake lever replaced</div>
        <div class="text-xs text-text-tertiary">Apr 12 2025 · 11,200 mi</div>
      </div>
      <div class="shrink-0 font-mono text-sm font-medium text-text-primary">$42.00</div>
    </div>

    <div class="flex items-center gap-3 rounded-md border border-border-muted bg-surface-raised px-3 py-2.5">
      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-sm bg-[var(--type-inspection-bg)] text-[var(--type-inspection-color)]">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.3"></circle>
          <path d="M10.5 10.5L13.5 13.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
        </svg>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-[10px] font-bold tracking-[0.1em] text-[var(--type-inspection-color)] uppercase">Inspection</div>
        <div class="truncate text-sm font-semibold text-text-primary">Annual roadworthy check</div>
        <div class="text-xs text-text-tertiary">Jan 5 2025 · 10,400 mi</div>
      </div>
      <div class="shrink-0 font-mono text-sm font-medium text-text-primary">$65.00</div>
    </div>
  </div>
</div>
