---
import MotorcycleIcon from '../icons/MotorcycleIcon.astro';

const vehicles = [
  {
    name: 'The Daily',
    meta: 'Hyosung · Aquila 650 EFI · 2011',
    odometer: '14,230',
    unit: 'mi',
    entries: '3',
  },
  {
    name: 'Sunday Bike',
    meta: 'Ducati · Multistrada 1200S Gran Turismo · 2013',
    odometer: '8,402',
    unit: 'mi',
    entries: '0',
  },
  {
    name: 'Project Garage Find',
    meta: 'Harley-Davidson · Sportster XL1200L · 2007',
    odometer: '31,118',
    unit: 'mi',
    entries: '0',
  },
];
---

<div class="p-5 sm:p-6">
  <p class="mb-1 inline-flex items-center gap-1.5 text-xs font-semibold tracking-[0.1em] text-accent uppercase">
    <span class="h-px w-3.5 bg-current"></span>
    Your garage
  </p>
  <h3 class="font-display text-xl font-semibold tracking-tight text-text-primary sm:text-2xl">
    3 <span class="font-normal text-text-tertiary">vehicles</span>
  </h3>
  <p class="mt-1 text-xs text-text-tertiary">Sorted by most recently logged</p>

  <div class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
    {
      vehicles.map((vehicle) => (
        <div class="rounded-lg border border-border-muted bg-surface-raised p-4">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-md border border-border-default bg-surface-elevated text-accent">
            <MotorcycleIcon class="h-5 w-auto" />
          </div>
          <h4 class="font-display text-sm font-semibold tracking-tight text-text-primary">{vehicle.name}</h4>
          <p class="mb-4 text-xs text-text-tertiary">{vehicle.meta}</p>
          <div class="flex items-end justify-between border-t border-border-muted pt-3">
            <div>
              <div class="font-mono text-base font-medium tracking-tight text-text-primary">
                {vehicle.odometer}
                <span class="ml-0.5 text-[10px] font-normal text-text-tertiary">{vehicle.unit}</span>
              </div>
              <div class="mt-1 text-[10px] tracking-[0.08em] text-text-tertiary uppercase">Odometer</div>
            </div>
            <div>
              <div class="font-mono text-base font-medium tracking-tight text-text-primary">{vehicle.entries}</div>
              <div class="mt-1 text-[10px] tracking-[0.08em] text-text-tertiary uppercase">Log entries</div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</div>
