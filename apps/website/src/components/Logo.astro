---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span class={`inline-flex items-center gap-2 ${className}`}>
  <svg width="28" height="28" viewBox="0 0 36 36" fill="none" aria-hidden="true">
    <path d="M 11 30 A 14 14 0 1 1 25 30" stroke="var(--border-muted)" stroke-width="3" stroke-linecap="round"></path>
    <path d="M 11 30 A 14 14 0 1 1 30.1 11" stroke="var(--accent)" stroke-width="3" stroke-linecap="round"></path>
    <line x1="18" y1="18" x2="27.5" y2="13" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"></line>
    <circle cx="18" cy="18" r="2.2" fill="var(--accent)"></circle>
    <circle cx="30.1" cy="11" r="1.5" fill="var(--danger)" opacity="0.8"></circle>
  </svg>
  <span class="font-display text-lg leading-none tracking-tight">
    <span class="font-light text-text-primary">Rev</span><span class="font-bold text-accent">log</span>
  </span>
</span>
