---
import PhoneFrame from './mockups/PhoneFrame.astro';
import MobileGarageMockup from './mockups/MobileGarageMockup.astro';
---

<section class="border-t border-border-muted px-6 py-20 sm:py-28">
  <div class="mx-auto grid max-w-6xl items-center gap-16 lg:grid-cols-2">
    <div class="order-2 lg:order-1">
      <p class="mb-3 inline-flex items-center gap-2 text-sm font-semibold tracking-widest text-accent uppercase">
        <span class="h-px w-3.5 bg-current"></span>
        Mobile app
      </p>
      <h2 class="font-display text-3xl font-semibold tracking-tight text-text-primary sm:text-4xl">
        Revlog, in your pocket
      </h2>
      <p class="mt-4 text-lg text-text-secondary">
        A native app for logging maintenance trackside, in the garage, or at the pump — wherever your
        bike is. We're building it now.
      </p>
      <span
        data-testid="mobile-coming-soon-badge"
        class="mt-6 inline-flex items-center gap-2 rounded-full border border-accent bg-accent-muted px-4 py-1.5 text-xs font-semibold tracking-wide text-accent-light uppercase"
      >
        Coming soon
      </span>
    </div>

    <div data-testid="mobile-app-mockup" class="order-1 lg:order-2">
      <PhoneFrame>
        <MobileGarageMockup />
      </PhoneFrame>
    </div>
  </div>
</section>
